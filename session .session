					group = "+snippet",
					mode = "v",
					icon = { icon = "✀ " },
				},
			})
			return {
				{
					"<leader>Sa",
					function()
						require("scissors").addNewSnippet()
					end,
					desc = "✀  Add Snippet",
					mode = "v",
				},
				{
					"<leader>Se",
					function()
						require("scissors").editSnippet()
					end,
					desc = "✀  Edit Snippet",
				},
			}
		end,
	},
	{
		"rafamadriz/friendly-snippets",
