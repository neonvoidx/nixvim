221.             local qf = {}
222.             for _, item in ipairs(items) do
223.               qf[#qf + 1] = {
224.                 filename = Snacks.picker.util.path(item),
225.                 bufnr = item.buf,
226.                 lnum = item.pos and item.pos[1] or 1,
227.                 col = item.pos and item.pos[2] + 1 or 1,
228.                 end_lnum = item.end_pos and item.end_pos[1] or nil,
229.                 end_col = item.end_pos and item.end_pos[2] + 1 or nil,
230.                 text = item.line or item.comment or item.label or item.name or item.detail or item.text,
231.                 pattern = item.search,
232.                 valid = true,
233.               }
234.             end
235.             vim.fn.setqflist(qf, "a")
236.             vim.cmd("botright copen")
237.           end
