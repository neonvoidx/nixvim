$ # Use nix store prefetch-file for GitHub archives - faster approach
prefetch_github() {
  local owner=$1 repo=$2 rev=$3
  local url="https://github.com/$owner/$repo/archive/$rev.tar.gz"
  nix store prefetch-file --hash-type sha256 --unpack "$url" 2>&1 | grep "hash:" | awk '{print $2}'
}

