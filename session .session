      gitscripts.setup(opts)

      vim.api.nvim_create_autocmd({ "BufEnter", "VimEnter" }, {
        callback = function()
          gitscripts.async_pull()
        end,
        desc = "Auto pull repo on enter",
      })
    end,
  },
  {
    "noamsto/resolved.nvim",
    dependencies = { "nvim-lua/plenary.nvim" },
    event = "VeryLazy",
    opts = {},
  },
}

