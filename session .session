50.               if status then
51.                 return status.kind == "Error" and "DiagnosticError" or status.busy and "DiagnosticWarn" or "Special"
52.               end
53.             end,
54.             cond = function()
55.               local status = require("sidekick.status")
56.               return status.get() ~= nil
57.             end,
58.           },
