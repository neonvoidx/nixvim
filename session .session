4.   inputs = {
5.     nixpkgs.url = "github:nixos/nixpkgs/nixpkgs-unstable";
6.     nixvim.url = "github:nix-community/nixvim";
7.     flake-parts.url = "github:hercules-ci/flake-parts";
8.   };
9. 
10.   outputs =
11.     { nixvim, flake-parts, ... }@inputs:
12.     flake-parts.lib.mkFlake { inherit inputs; } {
13.       systems = [
14.         "x86_64-linux"
15.         "aarch64-linux"
16.         "x86_64-darwin"
17.         "aarch64-darwin"
18.       ];
19. 
20.       perSystem =
21.         { system, ... }:
22.         let
23.           nixvimLib = nixvim.lib.${system};
24.           nixvim' = nixvim.legacyPackages.${system};
25.           nixvimModule = {
26.             inherit system;
27.             module = import ./config;
28.           };
29.           nvim = nixvim'.makeNixvimWithModule nixvimModule;
30.         in
31.         {
32.           checks = {
33.             default = nixvimLib.check.mkTestDerivationFromNixvimModule nixvimModule;
34.           };
35.           packages = {
36.             default = nvim;
37.           };
38.         };
39.     };
40. }
41.
