      event = [ "FocusGained" "TermClose" "TermLeave" ];
      group = "autocmd_checktime";
      command = "checktime";
    }

    # Resize splits
    {
      event = [ "VimResized" ];
      group = "autocmd_resize_splits";
      callback.__raw = ''
        function()
          local current_tab = vim.fn.tabpagenr()
          vim.cmd("tabdo wincmd =")
          vim.cmd("tabnext " .. current_tab)
        end
      '';
